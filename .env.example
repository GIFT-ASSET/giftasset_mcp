# Transport: stdio | sse | streamable-http
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Upstream GiftAsset API
GIFTASSET_API_URL=https://api.giftasset.dev/

# Optional fallback API key (used only when client request has no
# X-API-Key / X-API-Token header). Get one from @giftassetmcp_bot
GIFTASSET_API_KEY=
