# Transport: stdio | sse | streamable-http
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000

# DNS-rebinding protection (MCP SDK). When serving behind a public domain,
# either list allowed hosts/origins or disable the check entirely.
# MCP_ALLOWED_HOSTS=your.domain.com,your.domain.com:*
# MCP_ALLOWED_ORIGINS=https://your.domain.com
# MCP_DNS_REBINDING_PROTECTION=off

# Max cached per-API-key HTTP clients (LRU)
# MCP_CLIENT_CACHE_MAX=128

# Upstream GiftAsset API
GIFTASSET_API_URL=https://api.giftasset.dev/

# Optional fallback API key (used only when client request has no
# X-API-Key / X-API-Token header). Get one from @giftassetmcp_bot
GIFTASSET_API_KEY=
